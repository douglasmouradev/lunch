<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # CSS/JS (document root na raiz do projeto — aaPanel padrão)
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]

    RewriteRule ^admin/?$ admin/index.php [L]

    DirectoryIndex index.php
</IfModule>

# Bloqueia acesso direto a pastas sensíveis (Apache 2.4+)
<IfModule mod_authz_core.c>
    <DirectoryMatch "^(config|setup|src|storage|data|views)(/|$)">
        Require all denied
    </DirectoryMatch>
</IfModule>
