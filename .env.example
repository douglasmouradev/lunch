# Copie para .env e preencha com os dados do painel (aaPanel / MySQL).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_CHARSET=utf8mb4

APP_ENV=production
APP_TIMEZONE=America/Bahia
KIOSK_REFRESH_SECONDS=120
# PIN de acesso ao sistema (marcação + quiosque). Deixe vazio só em ambiente local.
KIOSK_PIN=2024
KIOSK_REQUIRE_EMPLOYEE_PIN=true
KIOSK_IDLE_MINUTES=15
MARKING_MODE=open
